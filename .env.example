DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here

# Optional: faster slash command sync for one Discord server.
# Without this, commands are registered globally and may take longer to appear.
# DISCORD_GUILD_ID=your_test_server_id_here

# Optional: comma-separated Discord user IDs that can run global sync.
BOT_OWNER_IDS=123456789012345678

# Optional: set true to sync commands when the bot starts.
AUTO_SYNC_COMMANDS=false
# Optional: guild or global. Leave blank to use guild when DISCORD_GUILD_ID exists, otherwise global.
SYNC_SCOPE=

# Nocoin economy settings.
STARTING_BALANCE=1000
FISHING_COOLDOWN_SECONDS=300
# Begging is available once per Korean calendar day and resets at 00:00 Asia/Seoul.

# Firestore storage.
STORAGE_BACKEND=firestore
FIRESTORE_PROJECT_ID=your_firebase_project_id_here
FIRESTORE_COLLECTION=nocoinBot
FIRESTORE_DOCUMENT=state

# Use one of these for Firebase Admin credentials outside Google Cloud.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_firebase_project_id_here"}
# FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json

# Optional local JSON fallback only.
# STORAGE_BACKEND=json
# DATA_FILE=data/db.json
