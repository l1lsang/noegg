DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here

# Optional: faster slash command sync for one Discord server.
DISCORD_GUILD_ID=your_test_server_id_here

# Optional: comma-separated Discord user IDs that can run global sync.
BOT_OWNER_IDS=123456789012345678

# Optional: set true to sync commands when the bot starts.
AUTO_SYNC_COMMANDS=false
SYNC_SCOPE=guild

# Nocoin economy settings.
STARTING_BALANCE=1000
FISHING_COOLDOWN_SECONDS=300
BEGGING_COOLDOWN_SECONDS=600

# Render persistent disk can point this to /opt/render/project/src/data/db.json
DATA_FILE=data/db.json
